{
  "name": "filter-now",
  "type": "module",
  "version": "0.0.4",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "description": "An offline tool help user to add CSS based filter to image and save it.",
  "repository": "ntnyq/filter-now",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "compile": "vue-tsc --noEmit",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "lint": "eslint",
    "postinstall": "wxt prepare",
    "prepare": "husky",
    "release": "bumpp",
    "typecheck": "vue-tsc --noEmit",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "@ntnyq/utils": "^0.15.0",
    "@shikijs/core": "^4.2.0",
    "@shikijs/engine-javascript": "^4.2.0",
    "@shikijs/langs": "^4.2.0",
    "@shikijs/themes": "^4.2.0",
    "@tanstack/vue-table": "^8.21.3",
    "@unocss/reset": "^66.7.2",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "uncase": "^0.2.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/ri": "^1.2.10",
    "@ntnyq/eslint-config": "^6.1.5",
    "@ntnyq/prettier-config": "^3.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-vue": "^1.0.3",
    "@wxt-dev/unocss": "^1.0.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "unocss-preset-animations": "^1.3.0",
    "unocss-preset-shadcn": "^1.0.1",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5",
    "wxt": "^0.20.26"
  },
  "nano-staged": {
    "*.{js,ts,cjs,mjs,vue,md,yml,yaml,toml,json}": "eslint --fix",
    "*.{css,scss,html}": "prettier -uw"
  }
}
